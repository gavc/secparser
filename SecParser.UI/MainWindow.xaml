<Window x:Class="SecParser.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SecParser.UI"
        mc:Ignorable="d"
        Title="SecParser" Height="600" Width="1000" Icon="assets/secparser.ico">
    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Local Log..." Command="{Binding OpenLogCommand}" />
                <MenuItem Header="Open _Remote Log..." Command="{Binding OpenRemoteLogCommand}" />
                <Separator />
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}" />
            </MenuItem>
            <MenuItem Header="_Settings">
                <MenuItem Header="Show System Accounts" IsCheckable="True" IsChecked="{Binding ShowSystemAccounts}" />
            </MenuItem>
            <MenuItem Header="_Export">
                <MenuItem Header="Export as _Excel (.xlsx)..." Command="{Binding ExportExcelCommand}" />
                <MenuItem Header="Export as _PDF (.pdf)..." Command="{Binding ExportPdfCommand}" />
            </MenuItem>
        </Menu>

        <!-- Tool / Filter Bar -->
        <ToolBar DockPanel.Dock="Top" Padding="5">
            <Label Content="Users:" VerticalAlignment="Center"/>

            <!-- ToggleButton opens the user-filter popup -->
            <ToggleButton x:Name="UserFilterToggle"
                          Width="210" Margin="5,0"
                          IsChecked="{Binding IsUserFilterOpen, Mode=TwoWay}"
                          HorizontalContentAlignment="Stretch" Padding="6,3"
                          PreviewMouseLeftButtonDown="UserFilterToggle_PreviewMouseLeftButtonDown">
                <DockPanel LastChildFill="True">
                    <TextBlock Text="▾" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="4,0,0,0" FontSize="10"/>
                    <TextBlock Text="{Binding SelectedUsersSummary}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </ToggleButton>

            <!-- Popup: search box + Select All/Clear All + scrollable checkbox list -->
            <Popup IsOpen="{Binding IsUserFilterOpen, Mode=TwoWay}"
                   PlacementTarget="{Binding ElementName=UserFilterToggle}"
                   Placement="Bottom"
                   StaysOpen="False"
                   AllowsTransparency="True">
                <Border Background="White" BorderBrush="#AAAAAA" BorderThickness="1"
                        MinWidth="220" Padding="0,4">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="5" Opacity="0.25" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Inline search filters the list below -->
                        <TextBox Text="{Binding UserSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="6,2,6,5" Padding="3"
                                 ToolTip="Type to filter the user list"/>
                        <!-- Bulk-action buttons -->
                        <StackPanel Orientation="Horizontal" Margin="6,0,6,5">
                            <Button Content="Select All" Command="{Binding SelectAllUsersCommand}"
                                    Padding="6,2" Margin="0,0,6,0" FontSize="11"/>
                            <Button Content="Clear All" Command="{Binding ClearAllUsersCommand}"
                                    Padding="6,2" FontSize="11"/>
                        </StackPanel>
                        <Separator Margin="0,0,0,2"/>
                        <!-- Filtered user checkboxes -->
                        <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding FilteredAvailableUsers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding UserName}"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Margin="8,2" Padding="2,0"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Popup>

            <Button Content="Clear Filter" Command="{Binding ClearFilterCommand}" Margin="5,0" Padding="10,0"/>
            <Separator/>
            <Button Content="Previous" Command="{Binding PreviousPageCommand}" Margin="5,0" Padding="10,0"/>
            <TextBlock Text="{Binding PageSummary}" VerticalAlignment="Center" Margin="5,0"/>
            <Button Content="Next" Command="{Binding NextPageCommand}" Margin="5,0" Padding="10,0"/>
            <Separator/>
            <Button Content="Cancel" Command="{Binding CancelOperationCommand}" Visibility="{Binding CancelButtonVisibility}" Margin="5,0" Padding="10,0"/>
        </ToolBar>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding ProcessedCount, StringFormat=Total Records: \{0\}}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding ParseWarningCount, StringFormat=Parse Warnings: \{0\}}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar IsIndeterminate="{Binding IsLoading}" Width="100" Height="15" Visibility="{Binding ProgressBarVisibility}" />
            </StatusBarItem>
        </StatusBar>

        <!-- Data Grid -->
        <DataGrid ItemsSource="{Binding FilteredEvents}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                  EnableRowVirtualization="True" EnableColumnVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.CanContentScroll="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time" Binding="{Binding TimeCreated, StringFormat=\{0:yyyy-MM-dd HH:mm:ss\}}" />
                <DataGridTextColumn Header="Event ID" Binding="{Binding EventId}" />
                <DataGridTextColumn Header="Event Desc" Binding="{Binding EventDescription}" />
                <DataGridTextColumn Header="Computer" Binding="{Binding Computer}" />
                <DataGridTextColumn Header="Username" Binding="{Binding Username}" />
                <DataGridTextColumn Header="Target User" Binding="{Binding TargetUserName}" />
                <DataGridTextColumn Header="Target Domain" Binding="{Binding TargetDomainName}" />
                <DataGridTextColumn Header="Subject User" Binding="{Binding SubjectUserName}" />
                <DataGridTextColumn Header="Subject Domain" Binding="{Binding SubjectDomainName}" />
                <DataGridTextColumn Header="Logon ID" Binding="{Binding TargetLogonId}" />
                <DataGridTextColumn Header="IP Address" Binding="{Binding IpAddress}" />
                <DataGridTextColumn Header="Workstation" Binding="{Binding WorkstationName}" />
                <DataGridTextColumn Header="Process Name" Binding="{Binding ProcessName}" />
                <DataGridTextColumn Header="Command Line" Binding="{Binding CommandLine}" />
                <DataGridTextColumn Header="Logon Type" Binding="{Binding LogonType}" />
                <DataGridTextColumn Header="Logon Desc" Binding="{Binding LogonTypeDescription}" />
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" />
                <DataGridTextColumn Header="Failure Reason" Binding="{Binding FailureReason}" />
                <DataGridTextColumn Header="Auth Package" Binding="{Binding AuthenticationPackageName}" />
                <DataGridTextColumn Header="Service" Binding="{Binding ServiceName}" />
                <DataGridTextColumn Header="Share" Binding="{Binding ShareName}" />
                <DataGridTextColumn Header="Object" Binding="{Binding ObjectName}" />
                <DataGridTextColumn Header="Access" Binding="{Binding AccessList}" />
                <DataGridTextColumn Header="Member" Binding="{Binding MemberName}" />
                <DataGridTextColumn Header="Group" Binding="{Binding GroupName}" />
                <DataGridTextColumn Header="Category" Binding="{Binding TaskCategory}" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
